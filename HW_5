class YourAgent:
    def __init__(self, n_actions=5, nu=0.95):
        self.n_actions = n_actions
        self.nu = nu  # Фактор забывания старой информации
        self.reset()

    def reset(self):
        # Инициализируем априорные параметры Бета-распределения
        self._successes = np.ones(self.n_actions)
        self._failures = np.ones(self.n_actions)

    def get_action(self):
        # Сэмплируем вероятности из Бета-распределения для каждого действия
        samples = np.random.beta(self._successes, self._failures)
        return np.argmax(samples)

    def update(self, action, reward):
        # Экспоненциально сглаживаем прошлую статистику для всех действий,
        # чтобы агент адаптировался к дрейфу среды
        self._successes *= self.nu
        self._failures *= self.nu
        
        # Добавляем базовое априорное значение, чтобы параметры не уходили в 0
        self._successes += (1.0 - self.nu)
        self._failures += (1.0 - self.nu)

        # Добавляем новое наблюдение
        if reward == 1:
            self._successes[action] += 1.0
        else:
            self._failures[action] += 1.0

